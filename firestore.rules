rules_version = '2';

// Rules für RomaBeautyAcademy.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Freigabe-Anfragen für neue Admins: nur Admin-SDK (Server). Client gesperrt.
    match /pendingAdmins/{uid} {
      allow read, write: if false;
    }

    // Bild-Konfiguration der Website. Öffentlich lesbar (Echtzeit per onSnapshot),
    // Schreiben ausschließlich über das Admin-SDK (server-seitige Routen).
    match /config/siteImages {
      allow read: if true;
      allow write: if false;
    }

    // Sichtbarkeit der Startseiten-Sektionen. Öffentlich lesbar (Echtzeit),
    // Schreiben nur über das Admin-SDK.
    match /config/sections {
      allow read: if true;
      allow write: if false;
    }

    // Galerie-Einträge (Foto/Video). Öffentlich lesbar, Schreiben nur Admin-SDK.
    match /gallery/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Default: alles gesperrt.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
